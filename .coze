[project]
requires = [ "nodejs-24" ]
template = "nextjs"
version = "0.0.28"
appliedPatches = [ ]

[dev]
build = [ "bash", "./scripts/prepare.sh" ]
run = [ "bash", "./scripts/dev.sh" ]
validate = [ "bash", "./scripts/validate.sh" ]
deps = [ "git" ]

[deploy]
build = [ "bash", "./scripts/build.sh" ]
run = [ "bash", "./scripts/start.sh" ]
deps = [ "git" ]
